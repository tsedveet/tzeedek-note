# ─────────────────────────────────────────────────────────────
# VaultNote environment variables
# Copy this file to ".env.local" and fill in real values.
# ─────────────────────────────────────────────────────────────

# Neon Postgres connection string.
# Get it from: Neon Console → your project → Connection Details → "Pooled connection".
# Example: postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Secret used to sign session JWTs. Use a long random string (>= 32 chars).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET="change-me-to-a-long-random-secret"

# Google OAuth (optional — enables "Continue with Google").
# Create credentials at: https://console.cloud.google.com/apis/credentials
#   • OAuth client type: "Web application"
#   • Authorized redirect URIs:
#       http://localhost:3000/api/auth/google/callback
#       https://YOUR-APP.vercel.app/api/auth/google/callback   (after deploy)
# Leave blank to hide the Google button.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
